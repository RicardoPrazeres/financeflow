rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regras de segurança para FinanceFlow:
    // Garante que cada usuário autenticado possa ler e escrever apenas seus próprios dados.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
